# Discboard Environment Variables

# Discord (Required for bot)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Backend
DATABASE_URL=sqlite:///./discboard.db
API_PORT=8000
API_HOST=0.0.0.0
SECRET_KEY=change-this-secret-key-in-production

# Uptime Kuma (Optional - for service monitoring)
UPTIME_KUMA_URL=http://172.20.0.5:3001
UPTIME_KUMA_API_KEY=

# GitHub (Optional - for repo integration)
GITHUB_TOKEN=
GITHUB_ORG=BMillerCodes

# Hermes (Optional - for existing setup integration)
HERMES_API_URL=http://localhost:8000
HERMES_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000